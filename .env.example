# =============================================================
# SmartArquiteto - Variaveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha com suas chaves reais:
#   cp .env.example .env
#
# IMPORTANTE: Nunca commite o arquivo .env no Git!
# O .env ja deve estar no .gitignore.
# =============================================================

# --- Google Gemini Imagen 3 ---
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
# Selecione o projeto, clique em "Create API Key"
GEMINI_API_KEY=sua_chave_gemini_aqui

# --- Como ativar no terminal (Linux/Mac) ---
# export GEMINI_API_KEY="AIza..."
#
# --- Como ativar no Windows (PowerShell) ---
# $env:GEMINI_API_KEY="AIza..."
#
# --- Ou use python-dotenv ---
# Instale: pip install python-dotenv
# Crie um arquivo .env com: GEMINI_API_KEY=AIza...
# No app.py adicione no topo:
#   from dotenv import load_dotenv
#   load_dotenv()
